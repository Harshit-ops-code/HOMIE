# ─────────────────────────────────────────────────────────────────────────────
# Basera — Full Environment Variables Template (with AI/ML)
# cp .env.example .env.local  →  then fill in all values
# ⚠️  NEVER commit .env.local to GitHub
# ─────────────────────────────────────────────────────────────────────────────


# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://youruser:yourpassword@cluster0.abc123.mongodb.net/basera


# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=your_random_32_char_secret_here
NEXTAUTH_URL=http://localhost:3000


# ─── Google OAuth ─────────────────────────────────────────────────────────────
# console.cloud.google.com → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID=123456789-abc.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-abcdefghijklmnopqrstuvwxyz


# ─── Google Maps API ──────────────────────────────────────────────────────────
# Enable: Maps JavaScript API, Places API, Geocoding API
NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIzaSyABCDEFGHIJKLMNOPQRSTUVWXYZ123456


# ─── Google Vision API (for Auto Image Tagging) ───────────────────────────────
# Enable: Cloud Vision API (same Google Cloud project)
GOOGLE_VISION_API_KEY=AIzaSyABCDEFGHIJKLMNOPQRSTUVWXYZ123456


# ─── Cloudinary (image upload & CDN) ─────────────────────────────────────────
# cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=abcdefghijklmnopqrstuvwxyz12345


# ─── Anthropic Claude API (AI Features) ──────────────────────────────────────
# console.anthropic.com → API Keys → Create Key
# Powers: Chat Assistant, NL Search, Review Summarizer, Neighbourhood Score
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here


# ─── AI Feature Flags ─────────────────────────────────────────────────────────
# Set to "true" to enable, "false" to disable without code changes
NEXT_PUBLIC_AI_CHAT_ENABLED=true
NEXT_PUBLIC_AI_SEARCH_ENABLED=true
NEXT_PUBLIC_AI_SUMMARY_ENABLED=true
NEXT_PUBLIC_AI_NEIGHBOURHOOD_ENABLED=false


# ─── App Config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Basera
NEXT_PUBLIC_APP_URL=http://localhost:3000
